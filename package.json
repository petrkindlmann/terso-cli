{
  "name": "terso-cli",
  "version": "0.3.0",
  "description": "Terso CLI — compile AGENTS.md into per-agent configs and sync project knowledge from Omnus",
  "bin": {
    "terso": "./bin/terso.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/petrkindlmann/terso-cli"
  },
  "keywords": [
    "cli",
    "agents.md",
    "claude-code",
    "cursor",
    "copilot",
    "mcp",
    "context",
    "ai",
    "agent",
    "omnus"
  ],
  "files": [
    "dist",
    "bin",
    "hooks/omnus-session-observer.sh",
    "hooks/dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.0.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.1.0"
  }
}
